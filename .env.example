# Komga connection (required)
KOMGA_BASE_URL=http://komga:25600

# Komga auth - use API key (preferred) OR username/password
KOMGA_API_KEY=
KOMGA_USERNAME=admin@example.com
KOMGA_PASSWORD=password

# Suwayomi connection (required)
SUWAYOMI_BASE_URL=http://suwayomi:4567

# Suwayomi auth - only needed if Suwayomi has auth enabled
SUWAYOMI_USERNAME=
SUWAYOMI_PASSWORD=

# Sync behavior (optional)
INITIAL_SYNC_ON_START=true
POLLING_INTERVAL_SECONDS=300

# Title matching threshold (0.0-1.0, higher = stricter)
MATCH_THRESHOLD=0.85

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
